# Config de RUNTIME injetada no bundle do main em tempo de build (define no
# electron.vite.config.ts). Copie para `.env` (gitignored) e preencha para builds
# LOCAIS. O release OFICIAL injeta via secrets/env do CI (release.yml) — não usa
# este arquivo. Sem nenhuma destas envs, o app cai nos defaults: Cloud (login)
# desabilitado.

# URL base do projeto Supabase (login Cloud).
ORKESTRAL_SUPABASE_URL=

# ── Deploy self-hosted (VPS) — usado pelo docker-compose.yml e pelo install.sh ──
# Chave de RUNTIME (não é build-time). Em servidor sem keychain do SO, o Orkestral
# cifra os segredos com esta chave. Se ausente, cada boot gera uma nova e os
# segredos cifrados antes ficam ilegíveis — defina e mantenha estável.
# Gere com:  openssl rand -base64 32
ORKESTRAL_SECRET_KEY=

# Auth do agente dentro do container/serviço (opcional se você configurar a key
# pela página Provedores). Descomente a do seu provedor:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
